#!/bin/sh
# opkg stub — имитирует Entware opkg для тестирования

case "$1" in
    print-architecture)
        echo "arch all 1"
        echo "arch noarch 1"
        echo "arch mipsel_24kc 10"
        exit 0
        ;;
    list-installed)
        printf '%s\n' \
            "busybox - 1.36.1-1" \
            "curl - 8.5.0-1" \
            "wget - 1.21.4-1" \
            "iptables - 1.8.9-1" \
            "kmod-ipt-tproxy - 5.15.0-1"
        exit 0
        ;;
    install)
        shift
        echo "Installing $@..."
        echo "Installed $@"
        exit 0
        ;;
    update)
        echo "Downloading package list..."
        echo "Updated lists in /var/opkg-lists"
        exit 0
        ;;
    --version)
        echo "opkg version 2023.06.21"
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
