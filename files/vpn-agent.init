#!/bin/sh /etc/rc.common
# /etc/init.d/vpn-agent — автозапуск VPN агента через procd

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/vpn-agent.sh

start_service() {
    # Не запускаем если не зарегистрирован
    [ -f /etc/vpn/token ] || return 0

    procd_open_instance vpn-agent
    procd_set_param command "$PROG"
    # respawn: threshold(3600s) timeout(5s) retry(5)
    # если крашнулся 5 раз за час — остановить
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 0
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "vpn"
}
